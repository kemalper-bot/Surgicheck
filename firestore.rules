rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hasta formları — kimlik doğrulama olmadan yazılabilir (form gönderimi)
    // Ama okuma sadece giriş yapmış kullanıcılara (klinisyenler)
    match /cases/{caseId} {

      // Yeni vaka oluşturma: kimlik doğrulama gerekmez (hasta formu)
      // Sadece gerekli alanlar var ve status "patient_submitted" olmalı
      allow create: if
        request.resource.data.status == "patient_submitted" &&
        request.resource.data.keys().hasAll(["patient", "procedure", "risks", "createdAt"]) &&
        request.resource.data.patient.keys().hasAll(["fullName", "phone", "age"]);

      // Okuma ve güncelleme: sadece giriş yapmış kullanıcılar (klinisyenler)
      allow read, update: if request.auth != null;

      // Silme: hiçbir zaman izin verilmez
      allow delete: if false;
    }

    // Rıza formları — sadece giriş yapmış klinisyenler oluşturabilir ve okuyabilir
    match /consents/{consentId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // Postop takip soru setleri — herkes okuyabilir (hasta formu için), yazma yasak
    match /followupQuestions/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Postop takip programları — herkes okuyabilir, yazma yasak
    match /followupSchedules/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Postop takip yanıtları — hasta kimlik doğrulamasız oluşturabilir, okuma sadece klinisyen
    match /followupResponses/{responseId} {
      allow create: if
        request.resource.data.keys().hasAll(["caseId", "dayBucket", "answers", "submittedAt"]) &&
        request.resource.data.caseId is string &&
        request.resource.data.caseId.size() > 0;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // Fotoğraf protokolleri — herkes okuyabilir (hasta formu için), yazma yasak
    match /photoProtocols/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Fotoğraf yapılandırması (etiketler, talimatlar) — herkes okuyabilir, yazma yasak
    match /photoConfig/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
